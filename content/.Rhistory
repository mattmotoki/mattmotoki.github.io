data <- data.table(x)
var_names <- paste0('trace', seq_along(beta))
data[, (var_names) := mapply(p, alpha, beta, SIMPLIFY=F)]
plot_ly(data, type='scatter', mode='lines') %>%
add_trace(x=~x, y=~trace1, name='alpha=0.5, beta=0.5') %>%
add_trace(x=~x, y=~trace2, name=sprintf('alpha=%.1f, beta=%.1f', alpha[2], beta[2])) %>%
add_trace(x=~x, y=~trace3, name=sprintf('alpha=%.1f, beta=%.1f', alpha[3], beta[3])) %>%
add_trace(x=~x, y=~trace4, name=sprintf('alpha=%.1f, beta=%.1f', alpha[4], beta[4])) %>%
add_trace(x=~x, y=~trace5, name=sprintf('alpha=%.1f, beta=%.1f', alpha[5], beta[5])) %>%
add_trace(x=~x, y=~trace6, name=sprintf('alpha=%.1f, beta=%.1f', alpha[6], beta[6])) %>%
add_trace(x=~x, y=~trace7, name=sprintf('alpha=%.1f, beta=%.1f', alpha[7], beta[7])) %>%
layout(showlegend = TRUE,
yaxis = list(title = 'PDF', range = c(0,3)),
xaxis = list(title = NA, range = c(0,1))
)
