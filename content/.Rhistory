library(data.table)
library(plotly)
colors <- c(
'#FF7D29', '#249F3C', '#D8262F', '#9466B8',
'#8C564D', '#E574BE', '#7E7E7E', '#BBBC3C')
alpha <- c(0.5, 5, 1, 2, 2, 7.0, 1, 6)
beta  <- c(0.5, 1, 3, 2, 5, 2.5, 1, 6)
x <- seq(0.001, 0.999, length=1000)
# svg("tmp.svg",width=14,height=7)
plot(0, type='n', xlim=c(0,1), ylim=c(0,3), xlab=NA, ylab='PDF')
for (i in seq_along(beta)) {
lines(x, dbeta(x, alpha[i], beta[i]), col=colors[i], lwd=2)
}
